# ────────────────────────────────────────────────────────────
# Virtualenvs
# ────────────────────────────────────────────────────────────
/venv/
/.venv/

# ────────────────────────────────────────────────────────────
# IDE / Editor
# ────────────────────────────────────────────────────────────
/.idea/
/.vscode/

# ────────────────────────────────────────────────────────────
# Build artifacts
# ────────────────────────────────────────────────────────────
/build/
/dist/
main.spec

# ────────────────────────────────────────────────────────────
# Caches Python
# ────────────────────────────────────────────────────────────
__pycache__/
*.pyc

# ────────────────────────────────────────────────────────────
# Bibliotecas de terceiros embutidas
# ────────────────────────────────────────────────────────────
poppler-*/

# ────────────────────────────────────────────────────────────
# Dados sensíveis (NÃO commitar)
# ────────────────────────────────────────────────────────────
.env
sensiveis.py
Scai.WMB
*.WMB
*.ldb

# ────────────────────────────────────────────────────────────
# Bancos do webapp (estado local; cada usuário gera o seu)
# ────────────────────────────────────────────────────────────
webapp.db
webapp.db-journal

# ────────────────────────────────────────────────────────────
# Pastas de execução/saída
# ────────────────────────────────────────────────────────────
# (sem slash inicial = match em qualquer subpasta também)
Downloads/
Profile/
chrome-profile/
logs/
*.xlsx
*.txt
!requirements.txt
favicon.ico
chromedriver.exe

# ────────────────────────────────────────────────────────────
# Worktrees e sessões de agentes (Claude Code etc.)
# ────────────────────────────────────────────────────────────
/.claude/

# ────────────────────────────────────────────────────────────
# Backups
# ────────────────────────────────────────────────────────────
*.bak
